{
  "manifest_version": 3,
  "name": "Cook-Redis",
  "version": "0.2.0",
  "description": "Redis browser for Cook-Redis Rust backend",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8642/*",
    "http://localhost:8642/*"
  ],
  "action": {
    "default_title": "Cook-Redis 测试工具",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  }
}

